
@startuml
' === CONFIGURACIÓN DE ESTILO ===
skinparam handwritten false
skinparam shadow false
skinparam defaultFontName Arial

' Colores y bordes para los Actores
skinparam actor {
    BackgroundColor #2C3E50
    BorderColor #2C3E50
    FontColor #2C3E50
    FontSize 16
}

' Colores y bordes para los Casos de Uso
skinparam usecase {
    BackgroundColor #ECF0F1
    BorderColor #34495E
    ArrowColor #7F8C8D
    FontSize 13
}

' Estilo del contenedor del sistema
skinparam package {
    BackgroundColor White
    BorderColor #BDC3C7
    FontColor #7F8C8D
    Style rectangle
}

' Alineación Vertical (Top to Bottom)
top to bottom direction

' === DEFINICIÓN DE ACTORES ===
actor "Administrador\n(SysAdmin / Dev)" as Admin
actor "Usuario Final\n(Navegador Web)" as User

' === SISTEMA NEBULA ===
package "Sistema NEBULA (Servidor Autogestionado)" {
    
    ' Definición de Casos de Uso
    usecase "Configurar Hardening\n(UFW, SSH, Fail2Ban)" as UC1
    usecase "Instalar Dependencias\n(Docker Engine)" as UC2
    usecase "Desplegar Aplicación\n(Docker Compose)" as UC3
    usecase "Configurar Proxy & SSL\n(Nginx Proxy Manager)" as UC4
    usecase "Monitorizar Sistema\n(Netdata)" as UC5
    usecase "Realizar Backups\n(Configuraciones)" as UC6
    
    usecase "Acceder a App Web\n(HTTPS Seguro)" as UC7

    ' Truco visual: Líneas ocultas para forzar el orden vertical dentro de la caja
    UC1 -[hidden]-> UC2
    UC2 -[hidden]-> UC3
    UC3 -[hidden]-> UC4
    UC4 -[hidden]-> UC5
    UC5 -[hidden]-> UC6
}


' === RELACIONES ===
' Acciones del Administrador
Admin --> UC1
Admin --> UC2
Admin --> UC3
Admin --> UC4
Admin --> UC5
Admin --> UC6

' Acciones del Usuario
User .up.> UC7 : Petición HTTPS

' --- RELACIONES DE DEPENDENCIA MEJORADAS ---
' UC7 (Acceder) DEPENDE de que UC3 (Desplegar) y UC4 (Proxy/SSL) estén completos.
UC7 .down.> UC3 : <<depends on>>
UC7 .down.> UC4 : <<depends on>>
' (La relación de inclusión original se puede mantener o eliminar. Con estas dependencias, queda aún más claro.)
' UC7 .> UC4 : <<include>>  ' Esta línea ahora sería redundante.
@enduml
